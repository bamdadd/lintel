# Slack integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# PII vault encryption
PII_VAULT_ENCRYPTION_KEY=your-fernet-key

# Database (used by docker-compose for the lintel service)
LINTEL_DB_DSN=postgresql://lintel:lintel@postgres:5432/lintel

# NATS
LINTEL_NATS_URL=nats://nats:4222

# Model provider (default: anthropic, fallback: ollama)
LINTEL_MODEL_DEFAULT_PROVIDER=anthropic
LINTEL_MODEL_DEFAULT_MODEL=claude-sonnet-4-20250514
LINTEL_MODEL_FALLBACK_PROVIDER=ollama
LINTEL_MODEL_FALLBACK_MODEL=llama3.1:8b
LINTEL_MODEL_OLLAMA_API_BASE=http://localhost:11434

# Resource budgeting — prevents concurrent container crashes
LINTEL_MAX_CONCURRENT_WORKFLOWS=10
LINTEL_MAX_CONCURRENT_SANDBOXES=8
